# --- LLM ---
GOOGLE_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-3-pro

# --- Identity / legacy shared secret (deprecated; prefer JWT/API keys) ---
EMAIL=your_email
SECRET=your_secret
ALLOW_LEGACY_SECRET=true

# --- Auth (E4) ---
# MUST be set in production; if unset, an ephemeral secret is generated and
# tokens are invalidated on every restart.
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Persistence (E2) ---
# SQLite by default (no external service). Point at Supabase/Postgres in prod:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/postgres
DATABASE_URL=sqlite:///./data/runs.db

# --- CORS (comma-separated origins, or *) ---
ALLOWED_ORIGINS=*

# --- Agent limits ---
RECURSION_LIMIT=5000
MAX_TOKENS=60000

# --- Sandbox hardening (E5) ---
RUN_CODE_TIMEOUT=120
RUN_CODE_CPU_SECONDS=60
RUN_CODE_MEM_MB=2048
RUN_CODE_ENFORCE_MEM=false
RUN_CODE_ALLOW_NETWORK=true

# --- Observability (E3, optional LangSmith) ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=quiz-solver-agent
